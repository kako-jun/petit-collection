---
import Base from '@/layouts/Base.astro';
---

<Base title="Book" description="Arrange assets on pages">
  <section class="book">
    <div class="book-header">
      <h1 id="book-title">Book</h1>
      <a href="/library" class="btn btn-sm">← Library</a>
    </div>
    <div id="book-container" class="book-container">
      <p class="empty">Loading…</p>
    </div>
  </section>
</Base>

<script>
  import { loadBook, addPage } from '@/lib/db';
  import { renderBook } from '@/lib/book';
  import type { Book } from '@/lib/types';

  let book: Book | null = null;
  let currentIndex = 0;

  const container = document.getElementById('book-container')!;
  const titleEl = document.getElementById('book-title')!;

  function render() {
    if (!book) {
      container.innerHTML =
        '<p class="empty">No book yet. <a href="/library">Go to Library</a> and add seed data first.</p>';
      return;
    }
    titleEl.textContent = book.title;
    renderBook(
      container,
      book,
      currentIndex,
      (idx) => {
        if (idx < 0 || idx >= book!.pages.length) return;
        currentIndex = idx;
        render();
      },
      async () => {
        try {
          book = await addPage(book!);
          currentIndex = book.pages.length - 1;
          render();
        } catch (e) {
          console.error('Failed to add page', e);
        }
      },
    );
  }

  async function init() {
    book = await loadBook();
    render();
  }

  init();
</script>
